{
  "$schema": "https://schema.tauri.app/config/v2",
  "productName": "ErgoLearn AI",
  "version": "0.1.0",
  "identifier": "com.ergolearn.ai",
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/ergolearn-backend"
    ]
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "ErgoLearn AI",
        "width": 1100,
        "height": 750,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "build": {
    "beforeDevCommand": "npm run dev:frontend",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../src-frontend"
  }
}
